---
const steps = [
  { icon: 'wallet2', label: 'Paso 1', title: 'Deposita tu capital', text: 'Elige el plan que mejor se adapte a tus objetivos.' },
  { icon: 'sun', label: 'Paso 2', title: 'Se invierte en proyectos', text: 'Tu dinero se destina a proyectos de energia solar y eolica.' },
  { icon: 'bar-chart-line', label: 'Paso 3', title: 'Genera rendimientos', text: 'Los proyectos generan ingresos por produccion energetica.' },
  { icon: 'display', label: 'Paso 4', title: 'Recibe tus beneficios', text: 'Visualiza y gestiona tus resultados desde tu panel.' },
];
---

<section id="como-funciona" class="rounded-[2rem] border border-emerald-100 bg-gradient-to-b from-white to-emerald-50 px-6 py-12 shadow-[0_24px_60px_rgba(12,23,15,0.06)] md:px-10 md:py-16" data-reveal>
  <div class="mx-auto max-w-6xl">
    <div class="mb-10 text-center md:mb-12">
      <p class="mb-2 text-xs font-extrabold uppercase tracking-[0.18em] text-emerald-700">Como funciona</p>
      <h2 class="[font-family:'Plus_Jakarta_Sans',Manrope,sans-serif] text-3xl font-extrabold leading-none tracking-[-0.04em] text-slate-950 md:text-4xl">
        Asi funciona tu inversion
      </h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {steps.map((step) => (
        <article class="rounded-[1.75rem] border border-emerald-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
          <div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-100 to-cyan-50 text-xl text-emerald-800 shadow-sm">
            <i class={`bi bi-${step.icon}`}></i>
          </div>
          <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-emerald-700">{step.label}</p>
          <h3 class="mt-2 [font-family:'Plus_Jakarta_Sans',Manrope,sans-serif] text-xl font-bold text-slate-950">{step.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{step.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
