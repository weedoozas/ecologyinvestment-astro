---
import '../../styles/home/plans.css';
---

<section class="section-stack section-block section-plans-band" data-reveal>
  <div class="plans-atmosphere" aria-hidden="true">
    <span class="wind-streak wind-streak-1"></span>
    <span class="wind-streak wind-streak-2"></span>
    <span class="wind-streak wind-streak-3"></span>
    <div class="windmill-ornament">
      <span class="windmill-mast"></span>
      <span class="windmill-hub"></span>
      <span class="windmill-rotor">
        <span class="windmill-arm blade-a"><span class="windmill-blade"></span></span>
        <span class="windmill-arm blade-b"><span class="windmill-blade"></span></span>
        <span class="windmill-arm blade-c"><span class="windmill-blade"></span></span>
      </span>
    </div>
  </div>

  <div class="section-heading narrow">
    <p class="section-kicker">Planes de inversión</p>
    <h2>Planes diseñados para distintos niveles de inversión</h2>
  </div>

  <div class="plan-grid investment-grid">
    <article class="plan-card low investment-card">
      <i class="bi bi-tree-fill section-symbol"></i>
      <p class="plan-label">Eco-Básico (VIP 1)</p>
      <h3>$40.00 - $200.00 USD.</h3>
      <strong>25% Diario</strong>
      <ul class="spec-list">
        <li>Acceso inicial al portafolio sostenible</li>
        <li>Panel de seguimiento incluido</li>
      </ul>
      <a class="primary-button plan-cta" href="/planes">Elegir plan</a>
    </article>

    <article class="plan-card mid investment-card featured-plan">
      <i class="bi bi-bar-chart-fill section-symbol"></i>
      <p class="plan-label">Eco-Pro (VIP 2)</p>
      <h3>$400.00 - $800.00 USD.</h3>
      <strong>25% Diario</strong>
      <ul class="spec-list">
        <li>Mayor participación en proyectos</li>
        <li>Prioridad en nuevos proyectos</li>
      </ul>
      <a class="primary-button plan-cta" href="/planes">Elegir plan</a>
    </article>

    <article class="plan-card high investment-card">
      <i class="bi bi-shield-check section-symbol"></i>
      <p class="plan-label">Eco-Elite (VIP 3)</p>
      <h3>$1500.00 USD - $3000.00</h3>
      <strong>25% Diario</strong>
      <ul class="spec-list">
        <li>Acceso a oportunidades exclusivas</li>
        <li>Soporte personalizado</li>
      </ul>
      <a class="primary-button plan-cta" href="/planes">Elegir plan</a>
    </article>
  </div>
</section>
