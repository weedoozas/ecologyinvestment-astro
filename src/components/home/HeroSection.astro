---
import { plansUrl } from '../../data/site.js';
---

<section
  class="relative mx-[calc(50%-50vw)] overflow-hidden bg-[radial-gradient(circle_at_top_left,rgba(15,138,108,0.12),transparent_24%),linear-gradient(90deg,rgba(255,255,255,0.97)_0%,rgba(255,255,255,0.9)_26%,rgba(255,255,255,0.5)_48%,rgba(255,255,255,0.12)_66%),url('/images/greenprojects.png')] bg-cover bg-center px-4 pb-20 pt-20 md:px-8 md:pb-20 md:pt-20"
  data-hero-section
  data-reveal
>
  <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:items-end">
    <div class="max-w-3xl">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.18em] text-emerald-700">Eco-inversiones globales</p>
      <h1 class="mb-4 max-w-[14ch] [font-family:'Plus_Jakarta_Sans',Manrope,sans-serif] text-4xl font-extrabold leading-none tracking-[-0.04em] text-slate-950 md:text-5xl lg:text-6xl">
        Invierte en energia sostenible y haz crecer tu capital con impacto real
      </h1>
      <p class="max-w-2xl text-base leading-7 text-slate-600 md:text-lg md:leading-8">
        Participa en proyectos de energia renovable y accede a oportunidades de inversion disenadas para generar valor economico y ambiental.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-700 to-teal-500 px-6 py-3 text-sm font-bold text-white shadow-[0_18px_38px_rgba(16,103,124,0.24)] transition hover:-translate-y-0.5" href={plansUrl}>
          Empezar a invertir
        </a>
        <a class="inline-flex items-center justify-center rounded-full border border-emerald-100 bg-white/85 px-6 py-3 text-sm font-bold text-slate-700 transition hover:bg-white" href="#como-funciona">
          Ver como funciona
        </a>
      </div>
    </div>
  </div>
</section>
