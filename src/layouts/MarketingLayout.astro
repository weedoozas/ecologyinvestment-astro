---
import '../styles/site.css';
import { company, plansUrl } from '../data/site.js';

const {
  title = company.name,
  description = company.about,
  currentPath = '/',
} = Astro.props;

const navItems = [
  { href: '/sobre-nosotros', label: 'Quienes somos' },
  { href: plansUrl, label: 'Planes' },
  { href: '/contacto', label: 'Contacto' },
];

const whatsappHref = `https://wa.me/${company.phone.replace(/\D/g, '')}`;

const navLinkBase =
  'rounded-full px-4 py-2 text-sm font-semibold text-slate-600 transition hover:bg-white/80 hover:text-emerald-700';
const navLinkActive = 'bg-white text-emerald-700 shadow-sm ring-1 ring-emerald-100';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(255,255,255,0.98)),url('https://images.pexels.com/photos/7130537/pexels-photo-7130537.jpeg?auto=compress&cs=tinysrgb&w=1600')] bg-cover bg-fixed bg-top text-slate-950 [font-family:Manrope,Segoe_UI,sans-serif]">
    <header class="sticky top-0 z-30 border-b border-white/50 bg-white/80 backdrop-blur-xl" data-site-header>
      <div class="mx-auto flex w-full max-w-7xl items-center gap-4 px-4 py-3 md:px-6 lg:px-8">
        <a class="shrink-0" href="/">
          <img src="/images/logos/logo-transparent.png" alt={company.name} class="h-auto w-36 object-contain md:w-40" />
        </a>

        <button
          type="button"
          class="ml-auto inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-emerald-100 bg-white text-emerald-900 shadow-sm md:hidden"
          id="navToggleButton"
          aria-label="Abrir menu"
        >
          <i class="bi bi-list text-xl"></i>
        </button>

        <div
          class="hidden md:flex md:flex-1 md:items-center md:justify-between md:gap-6"
          id="mobileNavPanel"
        >
          <nav class="flex flex-wrap items-center gap-2" aria-label="Principal">
            {navItems.map((item) => (
              <a href={item.href} class={`${navLinkBase} ${currentPath === item.href ? navLinkActive : ''}`}>
                {item.label}
              </a>
            ))}
          </nav>

          <div class="flex items-center gap-3">
            <a class="text-sm font-semibold text-slate-600 transition hover:text-emerald-700" href={plansUrl}>
              Ver planes
            </a>
            <a
              class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-700 to-teal-500 px-5 py-2.5 text-sm font-bold text-white shadow-[0_18px_38px_rgba(16,103,124,0.24)] transition hover:-translate-y-0.5"
              href="/login"
            >
              Mi cuenta
            </a>
          </div>
        </div>
      </div>

      <div class="hidden border-t border-emerald-100 bg-white/95 px-4 py-4 shadow-lg md:hidden" id="mobileNavDrawer">
        <nav class="grid gap-2" aria-label="Principal movil">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`rounded-2xl px-4 py-3 text-sm font-semibold ${currentPath === item.href ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-50 text-slate-700'}`}
            >
              {item.label}
            </a>
          ))}
          <a class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700" href={plansUrl}>Ver planes</a>
          <a
            class="mt-2 inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-700 to-teal-500 px-5 py-3 text-sm font-bold text-white"
            href="/login"
          >
            Mi cuenta
          </a>
        </nav>
      </div>
    </header>

    <div class="mx-auto flex min-h-[calc(100vh-80px)] w-full max-w-7xl flex-col px-4 pb-0 pt-6 md:px-6 lg:px-8">
      <slot />

      <a
        class="fixed bottom-4 right-4 z-40 inline-flex h-14 w-14 items-center justify-center rounded-full bg-[#11b67a] shadow-[0_18px_34px_rgba(17,182,122,0.28)] md:bottom-6 md:right-6 md:h-[58px] md:w-[58px]"
        href={whatsappHref}
        target="_blank"
        rel="noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <img src="/images/illustrations/whatsapp.svg" alt="WhatsApp" class="h-6 w-6 brightness-0 invert" />
      </a>

      <footer class="mt-14 grid gap-8 rounded-t-[2rem] border border-white/10 bg-[radial-gradient(circle_at_top_right,rgba(95,177,121,0.14),transparent_22%),radial-gradient(circle_at_bottom_left,rgba(75,139,95,0.12),transparent_24%),linear-gradient(180deg,#223f2b_0%,#356444_100%)] px-6 py-10 text-white md:grid-cols-2 md:px-8">
        <div>
          <img src="/images/logos/logo-transparent.png" alt={company.name} class="mb-4 h-auto w-40" />
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-emerald-200">Contacto</p>
          <div class="space-y-2 text-sm text-emerald-50/90">
            <p>{company.location}</p>
            <p>{company.phone}</p>
            <p>{company.email}</p>
          </div>
        </div>
        <div>
          <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-emerald-200">Navegacion</p>
          <div class="grid gap-2 text-sm text-emerald-50/90">
            <a href="/">Inicio</a>
            <a href={plansUrl}>Planes</a>
            <a href="/contacto">Contacto</a>
          </div>
        </div>
      </footer>

      <div class="bg-neutral-950 px-4 py-4 text-center text-sm text-white">
        2026 Eco Negocios & Inversiones. Todos los derechos reservados.
      </div>
    </div>

    <script is:inline>
      const navToggleButton = document.querySelector('#navToggleButton');
      const mobileNavDrawer = document.querySelector('#mobileNavDrawer');
      const revealItems = document.querySelectorAll('[data-reveal]');

      navToggleButton?.addEventListener('click', () => {
        mobileNavDrawer?.classList.toggle('hidden');
      });

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('translate-y-6', 'opacity-0');
            entry.target.classList.add('translate-y-0', 'opacity-100');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });

      revealItems.forEach((item) => {
        item.classList.add('translate-y-6', 'opacity-0', 'transition-all', 'duration-700');
        observer.observe(item);
      });
    </script>
  </body>
</html>
