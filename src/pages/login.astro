---
import '../styles/site.css';
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
		<title>Login demo | Eco Negocios e Inversiones</title>
	</head>
  	<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-green-50 to-emerald-100 relative">
		<div class="absolute inset-0 bg-gradient-to-br from-green-900/20 to-transparent pointer-events-none"></div>
 		<div class="relative w-full max-w-md p-6">
 			<section class="bg-white/90 backdrop-blur-xl rounded-3xl p-8 shadow-2xl border border-white/50">
 				<div class="flex items-center gap-4 mb-6">
					<img src="/images/logos/logo-transparent.png" alt="Eco Negocios" class="w-24 h-10 object-contain" />
					<div>
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Acceso seguro</p>
						<h2 class="text-2xl font-bold text-green-900">Inicia sesión</h2>
					</div>
				</div>

				<form id="loginForm" class="space-y-4">
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Correo</span>
						<input type="email" name="email" placeholder="user@eco.demo" class="w-full px-4 py-3 rounded-2xl border border-green-200 bg-white" required />
					</label>
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Contrasena</span>
						<input type="password" name="password" placeholder="********" class="w-full px-4 py-3 rounded-2xl border border-green-200 bg-white" required />
					</label>
					<button type="submit" class="w-full py-3 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg">Entrar al dashboard</button>
					<p class="text-center text-sm font-bold text-red-500 min-h-5" id="loginMessage"></p>
				</form>

				<div class="mt-6 pt-4 border-t border-green-100">
					<p class="text-xs text-green-600 uppercase tracking-widest font-bold mb-2">Accesos demo</p>
					<div class="flex flex-col gap-2">
						<button type="button" class="px-4 py-2 rounded-xl bg-white border border-green-200 text-left text-sm hover:bg-green-50" data-demo-login="investor">user@eco.demo / user123</button>
						<button type="button" class="px-4 py-2 rounded-xl bg-white border border-green-200 text-left text-sm hover:bg-green-50" data-demo-login="admin">admin@eco.demo / admin123</button>
					</div>
				</div>

				<div class="flex justify-between mt-6 text-sm">
					<a href="/" class="text-green-600 hover:text-green-800">Volver a la landing</a>
					<a href="/dashboard" class="text-green-600 hover:text-green-800">Ir al dashboard</a>
				</div>
 			</section>
 		</div>

 		<script type="module" src="/demo-app.js"></script>
 	</body>
</html>
