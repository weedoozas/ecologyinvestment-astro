---
import '../styles/site.css';
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
		<title>Login demo | Eco Negocios e Inversiones</title>
	</head>
  	<body class="min-h-screen flex items-center justify-center relative p-4" style="background: linear-gradient(180deg, rgba(232,250,235,0.9) 0%, rgba(232,250,235,0.9) 100%), url('/images/greenprojects.png') center center/cover no-repeat;" data-page="login">
		<div class="absolute inset-0 bg-gradient-to-br from-green-900/20 to-transparent pointer-events-none"></div>
  		<div class="relative w-full max-w-md">
  			<section class="bg-white/50 backdrop-blur-xl rounded-3xl p-6 md:p-8 shadow-2xl border border-white/30">
  				<div class="flex items-center gap-3 md:gap-4 mb-4 md:mb-6">
					<img src="/images/logos/logo-transparent.png" alt="Eco Negocios" class="w-20 md:w-24 h-8 md:h-10 object-contain" />
					<div>
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Acceso seguro</p>
						<h2 class="text-xl md:text-2xl font-bold text-green-900">Inicia sesión</h2>
					</div>
				</div>

				<form id="loginForm" class="space-y-3 md:space-y-4">
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Correo</span>
						<input type="email" name="email" placeholder="user@eco.demo" class="w-full px-3 md:px-4 py-2.5 md:py-3 rounded-xl md:rounded-2xl border border-green-200 bg-white/80 text-base" required />
					</label>
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Contrasena</span>
						<input type="password" name="password" placeholder="********" class="w-full px-3 md:px-4 py-2.5 md:py-3 rounded-xl md:rounded-2xl border border-green-200 bg-white/80 text-base" required />
					</label>
					<button type="submit" class="w-full py-2.5 md:py-3 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg text-sm md:text-base">Entrar al dashboard</button>
					<p class="text-center text-sm font-bold text-red-500 min-h-5" id="loginMessage"></p>
				</form>

				<div class="flex flex-col md:flex-row justify-between mt-4 md:mt-6 text-sm gap-2">
					<a href="/" class="text-green-600 hover:text-green-800">Volver a la landing</a>
					<a href="/dashboard" class="text-green-600 hover:text-green-800">Ir a la demo</a>
				</div>
  			</section>
  		</div>

  		<script type="module" src="/demo-app.js"></script>
	</body>
</html>
