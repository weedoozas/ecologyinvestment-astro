<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
		<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
		<title>Dashboard | Eco Negocios e Inversiones</title>
	</head>
	<body class="bg-gradient-to-br from-green-50 to-emerald-100 min-h-screen">
		<div class="flex min-h-screen">
			<aside class="w-64 bg-gradient-to-b from-green-950 to-green-900 border-r border-green-800/30 fixed h-full flex flex-col p-4 gap-4" id="dashxSidebar">
				<div class="flex items-center justify-between">
					<a href="/" class="flex items-center gap-3">
						<img src="/images/logos/logo-transparent.png" alt="Eco Negocios" class="w-9 h-9" />
						<div>
							<span class="block text-xs text-green-300 uppercase tracking-widest">Eco Negocios</span>
							<strong class="block text-white">Dashboard</strong>
						</div>
					</a>
					<button type="button" class="w-9 h-9 rounded-lg border border-white/10 bg-white/5 text-white" id="sidebarToggle">
						<i class="bi bi-list"></i>
					</button>
				</div>

				<nav class="flex flex-col gap-2 mt-4" id="investorNav">
					<a href="#overview" class="sidebar-btn active"><i class="bi bi-grid-1x2 mr-2"></i>Resumen</a>
					<a href="#deposits" class="sidebar-btn"><i class="bi bi-plus-circle mr-2"></i>Deposito</a>
					<a href="#withdrawals" class="sidebar-btn"><i class="bi bi-arrow-up-circle mr-2"></i>Retiro</a>
				</nav>

				<nav class="flex flex-col gap-2 mt-4 hidden" id="adminNav">
					<button type="button" class="sidebar-btn active" data-admin-tab="transactions"><i class="bi bi-receipt mr-2"></i>Transacciones</button>
					<button type="button" class="sidebar-btn" data-admin-tab="graphics"><i class="bi bi-graph-up mr-2"></i>Graficos</button>
					<button type="button" class="sidebar-btn" data-admin-tab="beneficiaries"><i class="bi bi-people mr-2"></i>Beneficiarios</button>
				</nav>

				<div class="flex flex-col gap-2 mt-auto">
					<button type="button" class="sidebar-btn" id="switchInvestor"><i class="bi bi-person mr-2"></i>Demo Cuenta cliente</button>
					<button type="button" class="sidebar-btn" id="switchAdmin"><i class="bi bi-shield-check mr-2"></i>Demo Cuenta administradora</button>
				</div>
			</aside>

			<div class="fixed inset-0 bg-black/20 z-40 hidden" id="dashxOverlay"></div>

			<main class="flex-1 ml-64 p-6">
				<header class="flex items-center justify-between mb-6">
					<div>
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Cuenta</p>
						<h1 class="text-xl font-bold text-green-900" id="dashboardTitle">Resumen</h1>
					</div>
					<div class="flex items-center gap-3">
						<span class="px-3 py-1 rounded-full bg-white border border-green-200 text-green-700 text-sm font-bold">Activo</span>
						<div class="relative" id="userMenu">
							<button type="button" class="w-10 h-10 rounded-full bg-white border border-green-200 shadow-lg flex items-center justify-center text-green-900" id="userButton">
								<i class="bi bi-person-circle text-xl"></i>
							</button>
							<div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-xl border border-green-100 shadow-xl hidden" id="userDropdown">
								<div class="p-3 border-b border-green-100">
									<strong class="block text-green-900" id="userName">Juan Perez</strong>
									<span class="text-sm text-green-600" id="userEmail">juan@email.com</span>
								</div>
								<div class="p-2">
									<a href="#profile" class="flex items-center gap-2 p-2 rounded-lg hover:bg-green-50 text-sm"><i class="bi bi-pencil"></i> Editar perfil</a>
									<button type="button" class="flex items-center gap-2 p-2 rounded-lg hover:bg-green-50 text-sm w-full" id="logoutButton"><i class="bi bi-box-arrow-right"></i> Cerrar sesion</button>
								</div>
							</div>
						</div>
					</div>
				</header>

				<section id="overview" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
					<div class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
						<div class="flex items-center gap-3 mb-2">
							<div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-green-700"><i class="bi bi-wallet2 text-lg"></i></div>
							<span class="text-xs text-green-600 uppercase font-bold">Saldo actual</span>
						</div>
						<strong class="text-2xl text-green-900" id="currentBalance">$10,740.00</strong>
						<p class="text-xs text-green-500 mt-1">Capital aprobado</p>
					</div>
					<div class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
						<div class="flex items-center gap-3 mb-2">
							<div class="w-10 h-10 rounded-xl bg-green-200 flex items-center justify-center text-green-700"><i class="bi bi-graph-up-arrow text-lg"></i></div>
							<span class="text-xs text-green-600 uppercase font-bold">Ganancias</span>
						</div>
						<strong class="text-2xl text-green-900" id="totalEarnings">$740.00</strong>
						<p class="text-xs text-green-500 mt-1">Total generado</p>
					</div>
					<div class="bg-white rounded-2xl p-4 border border-amber-200 shadow-sm">
						<div class="flex items-center gap-3 mb-2">
							<div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center text-amber-700"><i class="bi bi-hourglass-split text-lg"></i></div>
							<span class="text-xs text-amber-600 uppercase font-bold">Depositos pend.</span>
						</div>
						<strong class="text-2xl text-amber-700" id="pendingDeposits">$750.00</strong>
						<p class="text-xs text-amber-500 mt-1">2 solicitudes</p>
					</div>
					<div class="bg-white rounded-2xl p-4 border border-red-200 shadow-sm">
						<div class="flex items-center gap-3 mb-2">
							<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-red-700"><i class="bi bi-cash-stack text-lg"></i></div>
							<span class="text-xs text-red-600 uppercase font-bold">Retiros pend.</span>
						</div>
						<strong class="text-2xl text-red-700" id="pendingWithdrawals">$200.00</strong>
						<p class="text-xs text-red-500 mt-1">1 solicitud</p>
					</div>
				</section>

				<section id="transactions" class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm mb-6">
					<div class="flex items-center justify-between mb-4">
						<div>
							<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Historial</p>
							<h2 class="text-lg font-bold text-green-900">Transacciones</h2>
						</div>
						<div class="flex gap-2">
							<select id="filterType" class="px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm">
								<option value="">Todos</option>
								<option value="deposit">Depositos</option>
								<option value="withdrawal">Retiros</option>
								<option value="earning">Ganancias</option>
							</select>
							<select id="filterStatus" class="px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm">
								<option value="">Todos</option>
								<option value="pending">Pendiente</option>
								<option value="approved">Aprobado</option>
								<option value="rejected">Rechazado</option>
							</select>
						</div>
					</div>
					<table class="w-full">
						<thead>
							<tr class="text-left text-xs text-green-600 font-semibold">
								<th class="pb-2 w-16">Fecha</th>
								<th class="pb-2">Referencia</th>
								<th class="pb-2 w-32">Estado</th>
								<th class="pb-2 w-24 text-right">Monto</th>
								<th class="pb-2 w-24 text-right">Saldo</th>
							</tr>
						</thead>
						<tbody id="transactionsTableBody" class="min-h-[200px]">
						</tbody>
					</table>
					<div class="flex items-center justify-between mt-3 pt-3 border-t border-green-100">
						<span class="text-xs text-green-600">Mostrando 1-5 de 8</span>
						<div class="flex gap-1">
							<button type="button" class="px-2 py-1 rounded text-xs bg-green-100 text-green-700 font-medium" data-page="prev">&laquo;</button>
							<button type="button" class="px-2 py-1 rounded text-xs bg-green-700 text-white font-medium" data-page="1">1</button>
							<button type="button" class="px-2 py-1 rounded text-xs bg-green-50 text-green-600 hover:bg-green-100" data-page="2">2</button>
							<button type="button" class="px-2 py-1 rounded text-xs bg-green-100 text-green-700 font-medium" data-page="next">&raquo;</button>
						</div>
					</div>
				</section>

				<section id="chartSection" class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm mb-6">
					<div class="mb-4">
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Rendimiento</p>
						<h2 class="text-lg font-bold text-green-900">Evolucion del saldo</h2>
					</div>
					<div class="h-48">
						<canvas id="performanceChart"></canvas>
					</div>
				</section>

				<section id="deposits" class="hidden grid md:grid-cols-2 gap-4">
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<div class="flex items-center justify-between mb-4">
							<div>
								<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Nuevo deposito</p>
								<h2 class="text-lg font-bold text-green-900">Realizar deposito</h2>
							</div>
							<i class="bi bi-plus-circle-fill text-2xl text-green-700"></i>
						</div>
						<form id="depositForm" class="space-y-3">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Monto USD</span>
								<input type="number" min="1" step="0.01" name="amount" placeholder="250.00" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1"># de comprobante bancario</span>
								<input type="text" name="reference" placeholder="Numero de comprobante" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Comprobante</span>
								<div class="relative">
									<input type="file" id="depositFile" name="file" accept="image/*" class="hidden" required />
									<label for="depositFile" class="flex items-center justify-center w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50 cursor-pointer hover:bg-green-100 transition-colors">
										<i class="bi bi-cloud-arrow-up text-green-600 mr-2"></i>
										<span class="text-green-600 text-sm" id="depositFileName">Subir imagen</span>
									</label>
								</div>
								<div id="depositPreview" class="hidden mt-2 relative inline-block">
									<img id="depositPreviewImg" class="w-24 h-24 object-cover rounded-lg border border-green-200" />
									<button type="button" id="depositRemoveImg" class="absolute -top-2 -right-2 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center text-xs hover:bg-red-600">&times;</button>
								</div>
							</label>
							<button type="submit" class="w-full py-3 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg">Enviar deposito</button>
						</form>
					</div>
				</section>

				<section id="withdrawals" class="hidden grid md:grid-cols-2 gap-4">
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<div class="flex items-center justify-between mb-4">
							<div>
								<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Nuevo retiro</p>
								<h2 class="text-lg font-bold text-green-900">Solicitar retiro</h2>
							</div>
							<i class="bi bi-arrow-up-right-circle-fill text-2xl text-green-700"></i>
						</div>
						<form id="withdrawForm" class="space-y-3">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Monto USD</span>
								<input type="number" min="1" step="0.01" name="amount" placeholder="120.00" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<div class="grid grid-cols-2 gap-3">
								<label class="block">
									<span class="block text-sm font-bold text-green-900 mb-1">Banco</span>
									<input type="text" name="bank" placeholder="Banco" class="w-full px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm" required />
								</label>
								<label class="block">
									<span class="block text-sm font-bold text-green-900 mb-1">Nro. Cuenta</span>
									<input type="text" name="account" placeholder="Cuenta" class="w-full px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm" required />
								</label>
							</div>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Cedula / ID</span>
								<input type="text" name="cedula" placeholder="V-12345678" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Nombre completo</span>
								<input type="text" name="name" placeholder="Juan Perez" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Correo electronico</span>
								<input type="email" name="email" placeholder="correo@email.com" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Telefono de contacto</span>
								<input type="tel" name="phone" placeholder="+54 11 1234 5678" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<button type="submit" class="w-full py-3 rounded-full bg-emerald-100 text-green-800 font-bold border border-green-200">Solicitar retiro</button>
						</form>
					</div>
				</section>

				<section id="profile" class="hidden bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
					<div class="mb-4">
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Cuenta</p>
						<h2 class="text-lg font-bold text-green-900">Mi perfil</h2>
					</div>
					<form id="profileForm" class="space-y-4">
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Nombre completo</span>
								<input type="text" name="name" value="Juan Perez" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Email</span>
								<input type="email" name="email" value="juan@email.com" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
						</div>
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Telefono</span>
								<input type="tel" name="phone" value="+54 11 1234 5678" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Fecha de registro</span>
								<input type="text" value="15/01/2024" disabled class="w-full px-4 py-3 rounded-xl border border-green-100 bg-gray-50 text-gray-500" />
							</label>
						</div>
						<button type="submit" class="py-3 px-6 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg">Guardar cambios</button>
					</form>
				</section>

				<section id="adminPanel" class="hidden">
					<div class="mb-4">
						<h2 class="text-xl font-bold text-gray-900">Panel de Administracion</h2>
					</div>
					
					<div id="adminTransactions" class="admin-tab-content">
						<div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
							<div class="flex items-center justify-between mb-4">
								<div>
									<p class="text-xs text-gray-500 uppercase tracking-widest font-bold">Admin</p>
									<h3 class="text-lg font-bold text-gray-900">Todas las transacciones</h3>
								</div>
								<select class="px-3 py-2 rounded-lg border border-gray-200 text-sm">
									<option>Todas</option>
									<option>Depositos</option>
									<option>Retiros</option>
									<option>Ganancias</option>
								</select>
							</div>
							<table class="w-full">
								<thead>
									<tr class="text-left text-xs text-gray-500 font-semibold border-b">
										<th class="pb-2 w-16">Fecha</th>
										<th class="pb-2">Usuario</th>
										<th class="pb-2">Referencia</th>
										<th class="pb-2 w-32">Estado</th>
										<th class="pb-2 w-24 text-right">Monto</th>
										<th class="pb-2 w-20">Accion</th>
									</tr>
								</thead>
								<tbody class="min-h-[200px]" id="adminTransactionsBody">
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">18/03</td>
										<td class="py-2 text-sm">Maria Garcia</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Transferencia #4521</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Aprobado</span></td>
										<td class="py-2 text-right text-green-600 font-semibold text-sm">+$500.00</td>
										<td class="py-2"></td>
									</tr>
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">18/03</td>
										<td class="py-2 text-sm">Carlos Lopez</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Efectivo</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Aprobado</span></td>
										<td class="py-2 text-right text-green-600 font-semibold text-sm">+$250.00</td>
										<td class="py-2"></td>
									</tr>
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">17/03</td>
										<td class="py-2 text-sm">Pedro Martinez</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Banco Pichincha</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Aprobado</span></td>
										<td class="py-2 text-right text-red-600 font-semibold text-sm">-$300.00</td>
										<td class="py-2"></td>
									</tr>
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">15/03</td>
										<td class="py-2 text-sm">Ana Rodriguez</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Transferencia #4490</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Aprobado</span></td>
										<td class="py-2 text-right text-green-600 font-semibold text-sm">+$1,500.00</td>
										<td class="py-2"></td>
									</tr>
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">18/03</td>
										<td class="py-2 text-sm">Juan Perez</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Transferencia #4522</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 text-xs font-medium">Pendiente</span></td>
										<td class="py-2 text-right text-amber-600 font-semibold text-sm">+$750.00</td>
										<td class="py-2">
											<button class="px-2 py-1 rounded bg-green-500 text-white text-xs hover:bg-green-600 mr-1"><i class="bi bi-check"></i></button>
											<button class="px-2 py-1 rounded bg-red-500 text-white text-xs hover:bg-red-600"><i class="bi bi-x"></i></button>
										</td>
									</tr>
									<tr class="border-b border-gray-100 h-10">
										<td class="py-2 text-sm">18/03</td>
										<td class="py-2 text-sm">Laura Gomez</td>
										<td class="py-2 text-sm text-gray-700 max-w-[120px] truncate">Efectivo</td>
										<td class="py-2"><span class="px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 text-xs font-medium">Pendiente</span></td>
										<td class="py-2 text-right text-amber-600 font-semibold text-sm">+$400.00</td>
										<td class="py-2">
											<button class="px-2 py-1 rounded bg-green-500 text-white text-xs hover:bg-green-600 mr-1"><i class="bi bi-check"></i></button>
											<button class="px-2 py-1 rounded bg-red-500 text-white text-xs hover:bg-red-600"><i class="bi bi-x"></i></button>
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

					<div id="adminGraphics" class="admin-tab-content hidden">
						<div class="grid md:grid-cols-3 gap-4 mb-6">
							<div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
								<p class="text-xs text-gray-500 uppercase font-bold">Total Depositos</p>
								<strong class="text-2xl text-gray-900">$45,230</strong>
							</div>
							<div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
