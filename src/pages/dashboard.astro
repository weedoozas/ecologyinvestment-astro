		<div id="toastContainer" class="fixed bottom-6 right-6 z-50 flex flex-col gap-2"></div>

		<div id="confirmModal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center">
			<div class="bg-white rounded-2xl p-5 w-full max-w-sm shadow-2xl">
				<div class="flex items-center justify-between mb-4">
					<h3 class="font-bold text-green-900" id="modalTitle">Confirmar accion</h3>
					<button type="button" class="w-8 h-8 rounded-lg hover:bg-green-100" id="modalClose"><i class="bi bi-x-lg"></i></button>
				</div>
				<p class="text-green-700 mb-4" id="modalMessage">Esta seguro de realizar esta accion?</p>
				<div class="flex gap-2 justify-end">
					<button type="button" class="px-4 py-2 rounded-full bg-emerald-100 text-green-800 font-bold" id="modalCancel">Cancelar</button>
					<button type="button" class="px-4 py-2 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold" id="modalConfirm">Confirmar</button>
				</div>
			</div>
		</div>

		<style>
			.sidebar-btn {
				padding: 6px 12px;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.05);
				color: #f4fbfc;
				font-size: 0.75rem;
				cursor: pointer;
				text-align: left;
				border: none;
				transition: background 0.15s;
			}
			.sidebar-btn:hover { background: rgba(255, 255, 255, 0.1); }
			.sidebar-btn.active { background: rgba(95, 177, 121, 0.3); }
		</style>
		<script>
			import "chart.js/auto";

			const sidebarToggle = document.querySelector('#sidebarToggle');
			const overlay = document.querySelector('#dashxOverlay');
			const toggleSidebar = () => {
				document.body.classList.toggle('sidebar-open');
				overlay.classList.toggle('hidden');
				overlay.classList.toggle('flex');
			};
			sidebarToggle?.addEventListener('click', toggleSidebar);
			overlay?.addEventListener('click', toggleSidebar);

			const userMenu = document.querySelector('#userMenu');
			const userButton = userMenu?.querySelector('#userButton');
			const userDropdown = document.querySelector('#userDropdown');
			userButton?.addEventListener('click', (e) => {
				e.stopPropagation();
				userDropdown.classList.toggle('hidden');
			});
			document.addEventListener('click', () => userDropdown?.classList.add('hidden'));

			const toastContainer = document.getElementById('toastContainer');
			function showToast(message, type = 'info') {
				const toast = document.createElement('div');
				toast.className = `px-4 py-3 rounded-xl bg-white shadow-xl flex items-center gap-2`;
				toast.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle text-green-500' : 'info-circle text-green-700'}"></i><span class="text-green-900 text-sm">${message}</span>`;
				toastContainer.appendChild(toast);
				setTimeout(() => toast.classList.add('translate-x-full', 'opacity-0'), 10);
				setTimeout(() => toast.remove(), 3000);
			}

			const confirmModal = document.getElementById('confirmModal');
			const modalClose = document.getElementById('modalClose');
			const modalCancel = document.getElementById('modalCancel');
			let modalResolve = null;

			function showConfirm(title, message) {
				document.getElementById('modalTitle').textContent = title;
				document.getElementById('modalMessage').textContent = message;
				confirmModal.classList.remove('hidden');
				confirmModal.classList.add('flex');
				return new Promise(resolve => { modalResolve = resolve; });
			}

			function closeModal() {
				confirmModal.classList.add('hidden');
				confirmModal.classList.remove('flex');
				if (modalResolve) modalResolve(false);
			}

			modalClose?.addEventListener('click', closeModal);
			modalCancel?.addEventListener('click', closeModal);
			confirmModal?.addEventListener('click', (e) => { if (e.target === confirmModal) closeModal(); });
			document.getElementById('modalConfirm')?.addEventListener('click', () => {
				closeModal();
				if (modalResolve) modalResolve(true);
			});

			document.querySelectorAll('[data-id].btn-approve, [data-id].btn-reject, [data-id][data-type]').forEach(btn => {
				btn.addEventListener('click', async () => {
					const id = btn.dataset.id;
					const type = btn.dataset.type;
					const isApprove = btn.querySelector('.bi-check');
					const action = isApprove ? 'aprobar' : 'rechazar';
					const confirmed = await showConfirm(
						`${action.charAt(0).toUpperCase() + action.slice(1)} ${type === 'deposit' ? 'deposito' : 'retiro'}`,
						`Esta seguro de ${action} esta transaccion?`
					);
					if (confirmed) {
						const item = btn.closest('[data-id]');
						item.style.opacity = '0.5';
						setTimeout(() => {
							item.remove();
							showToast(`Transaccion ${action}ada correctamente`, 'success');
						}, 300);
					}
				});
			});

			document.querySelectorAll('.btn-approve, .btn-reject').forEach(btn => {
				btn.addEventListener('click', async () => {
					const id = btn.dataset.id;
					const type = btn.dataset.type;
					const action = btn.classList.contains('btn-approve') ? 'aprobar' : 'rechazar';
					const confirmed = await showConfirm(
						`${action.charAt(0).toUpperCase() + action.slice(1)} ${type === 'deposit' ? 'deposito' : 'retiro'}`,
						`Esta seguro de ${action} esta transaccion?`
					);
					if (confirmed) {
						const item = btn.closest('.flex');
						item.style.opacity = '0.5';
						setTimeout(() => {
							item.remove();
							showToast(`Transaccion ${action}ada correctamente`, 'success');
						}, 300);
					}
				});
			});

			const depositFileInput = document.getElementById('depositFile');
			const depositFileName = document.getElementById('depositFileName');
			const depositPreview = document.getElementById('depositPreview');
			const depositPreviewImg = document.getElementById('depositPreviewImg');
			const depositRemoveImg = document.getElementById('depositRemoveImg');

			depositFileInput?.addEventListener('change', function() {
				const file = this.files[0];
				if (file) {
					depositFileName.textContent = file.name;
					const reader = new FileReader();
					reader.onload = function(e) {
						depositPreviewImg.src = e.target.result;
						depositPreview.classList.remove('hidden');
					};
					reader.readAsDataURL(file);
				}
			});

			depositRemoveImg?.addEventListener('click', function() {
				depositFileInput.value = '';
				depositFileName.textContent = 'Subir imagen';
				depositPreview.classList.add('hidden');
				depositPreviewImg.src = '';
			});

			document.getElementById('depositForm')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const btn = e.target.querySelector('button[type="submit"]');
				const originalText = btn.textContent;
				btn.disabled = true;
				btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Enviando...';
				const confirmed = await showConfirm('Confirmar deposito', 'Esta seguro de enviar este deposito?');
				if (confirmed) {
					setTimeout(() => {
						showToast('Deposito enviado correctamente', 'success');
						e.target.reset();
					}, 500);
				}
				btn.disabled = false;
				btn.textContent = originalText;
			});

			document.getElementById('withdrawForm')?.addEventListener('submit', async (e) => {
				e.preventDefault();
				const btn = e.target.querySelector('button[type="submit"]');
				const originalText = btn.textContent;
				btn.disabled = true;
				btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Enviando...';
				const confirmed = await showConfirm('Confirmar retiro', 'Esta seguro de solicitar este retiro?');
				if (confirmed) {
					setTimeout(() => {
						showToast('Retiro solicitado correctamente', 'success');
						e.target.reset();
					}, 500);
				}
				btn.disabled = false;
				btn.textContent = originalText;
			});

			document.getElementById('profileForm')?.addEventListener('submit', (e) => {
				e.preventDefault();
				showToast('Perfil actualizado correctamente', 'success');
			});

			const navLinks = document.querySelectorAll('.sidebar-btn');

			function showPage(pageId) {
				const sections = ['overview', 'chartSection', 'transactions', 'deposits', 'withdrawals', 'profile', 'adminPanel'];
				sections.forEach(id => {
					const el = document.getElementById(id);
					if (el) el.classList.add('hidden');
				});

				if (pageId === 'overview') {
					document.getElementById('overview').classList.remove('hidden');
					document.getElementById('chartSection').classList.remove('hidden');
					document.getElementById('transactions').classList.remove('hidden');
				} else if (pageId === 'deposits') {
					document.getElementById('deposits').classList.remove('hidden');
				} else if (pageId === 'withdrawals') {
					document.getElementById('withdrawals').classList.remove('hidden');
				} else if (pageId === 'profile') {
					document.getElementById('profile').classList.remove('hidden');
				} else if (pageId === 'admin') {
					document.getElementById('adminPanel').classList.remove('hidden');
				}
			}

			document.getElementById('switchAdmin')?.addEventListener('click', function() {
				showPage('admin');
				document.getElementById('dashboardTitle').textContent = 'Admin - Transacciones';
				document.body.classList.remove('sidebar-open');
				overlay?.classList.add('hidden');
				document.getElementById('dashxSidebar').classList.remove('from-green-950', 'to-green-900');
				document.getElementById('dashxSidebar').classList.add('from-gray-900', 'to-gray-950');
				document.getElementById('investorNav').classList.add('hidden');
				document.getElementById('adminNav').classList.remove('hidden');
				document.querySelectorAll('#adminNav .sidebar-btn').forEach(b => b.classList.remove('active'));
				document.querySelector('#adminNav .sidebar-btn').classList.add('active');
				document.querySelectorAll('.admin-tab-content').forEach(c => c.classList.add('hidden'));
				document.getElementById('adminTransactions').classList.remove('hidden');
			});

			document.querySelectorAll('#adminNav .sidebar-btn').forEach(btn => {
				btn.addEventListener('click', function() {
					document.querySelectorAll('#adminNav .sidebar-btn').forEach(b => b.classList.remove('active'));
					document.querySelectorAll('.admin-tab-content').forEach(c => c.classList.add('hidden'));
					btn.classList.add('active');
					const tabId = btn.getAttribute('data-admin-tab');
					document.getElementById('admin' + tabId.charAt(0).toUpperCase() + tabId.slice(1)).classList.remove('hidden');
					
					const titles = { transactions: 'Admin - Transacciones', graphics: 'Admin - Graficos', beneficiaries: 'Admin - Beneficiarios' };
					document.getElementById('dashboardTitle').textContent = titles[tabId] || 'Admin';
				});
			});

			document.querySelectorAll('#adminTransactionsBody button').forEach(btn => {
				btn.addEventListener('click', function(e) {
					e.preventDefault();
					const row = this.closest('tr');
					const statusCell = row.querySelector('td:nth-child(4)');
					const isApproved = this.querySelector('.bi-check') !== null;
					if (isApproved) {
						statusCell.innerHTML = '<span class="px-1.5 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Aprobado</span>';
					} else {
						statusCell.innerHTML = '<span class="px-1.5 py-0.5 rounded bg-red-100 text-red-700 text-xs font-medium">Rechazado</span>';
					}
					this.closest('td').innerHTML = '';
				});
			});

			document.getElementById('switchInvestor')?.addEventListener('click', function() {
				showPage('overview');
				document.getElementById('dashboardTitle').textContent = 'Resumen';
				document.body.classList.remove('sidebar-open');
				overlay?.classList.add('hidden');
				document.getElementById('dashxSidebar').classList.remove('from-gray-900', 'to-gray-950');
				document.getElementById('dashxSidebar').classList.add('from-green-950', 'to-green-900');
				document.getElementById('investorNav').classList.remove('hidden');
				document.getElementById('adminNav').classList.add('hidden');
			});

			navLinks.forEach(link => {
				link.addEventListener('click', (e) => {
					const href = link.getAttribute('href');
					if (href.startsWith('#')) {
						e.preventDefault();
						navLinks.forEach(l => l.classList.remove('active'));
						link.classList.add('active');
						const targetId = href.substring(1);
						showPage(targetId);
						document.body.classList.remove('sidebar-open');
						overlay?.classList.add('hidden');
						overlay?.classList.remove('flex');
						const title = targetId === 'overview' ? 'Resumen' : targetId === 'deposits' ? 'Nuevo deposito' : targetId === 'withdrawals' ? 'Nuevo retiro' : targetId === 'profile' ? 'Mi perfil' : 'Resumen';
						document.getElementById('dashboardTitle').textContent = title;
					}
				});
			});

			showPage('overview');

			document.querySelectorAll('.dashx-user-dropdown a').forEach(link => {
				link.addEventListener('click', (e) => {
					const href = link.getAttribute('href');
					if (href && href.startsWith('#')) {
						e.preventDefault();
						const targetId = href.substring(1);
						showPage(targetId);
						navLinks.forEach(l => l.classList.remove('active'));
						document.getElementById('dashboardTitle').textContent = 'Mi perfil';
						userDropdown.classList.add('hidden');
					}
				});
			});

			const allTransactions = [
				{ date: '18/03', type: 'deposit', amount: '+$500.00', ref: 'Transferencia #4521', balance: 11290 },
				{ date: '18/03', type: 'deposit', amount: '+$250.00', ref: 'Efectivo', balance: 10790 },
				{ date: '15/03', type: 'withdrawal', amount: '-$200.00', ref: 'Banco Pichincha', balance: 10540 },
				{ date: '10/03', type: 'deposit', amount: '+$2,000.00', ref: 'Transferencia #4518', balance: 10740 },
				{ date: '28/02', type: 'earning', amount: '+$390.00', ref: 'Rendimiento Feb', balance: 8740 },
				{ date: '15/02', type: 'deposit', amount: '+$3,000.00', ref: 'Transferencia #4490', balance: 8350 },
				{ date: '28/01', type: 'earning', amount: '+$350.00', ref: 'Rendimiento Ene', balance: 5350 },
				{ date: '10/01', type: 'deposit', amount: '+$5,000.00', ref: 'Deposito inicial', balance: 5000 }
			];
			const itemsPerPage = 5;
			let currentPage = 1;

			function getStatusLabel(t) {
				if (t.type === 'deposit') return { label: 'Deposito pendiente', class: 'bg-amber-100 text-amber-700' };
				if (t.type === 'withdrawal') return { label: 'Retiro pendiente', class: 'bg-red-100 text-red-700' };
				if (t.type === 'earning') return { label: 'Ganancia', class: 'bg-emerald-100 text-emerald-700' };
				return { label: 'Deposito', class: 'bg-green-100 text-green-700' };
			}

			function renderTransactions(page) {
				const tbody = document.getElementById('transactionsTableBody');
				const start = (page - 1) * itemsPerPage;
				const end = start + itemsPerPage;
				let items = allTransactions.slice(start, end);
				
				while (items.length < itemsPerPage) {
					items.push({ date: '', type: '', amount: '', ref: '', balance: 0, empty: true });
				}

				tbody.innerHTML = items.map((t, i) => {
					if (t.empty) {
						return `<tr class="border-t border-green-100 h-10"><td class="py-2"></td><td class="py-2"></td><td class="py-2"></td><td class="py-2"></td><td class="py-2"></td></tr>`;
					}
					const status = getStatusLabel(t);
					const prevBalance = allTransactions[start + i + 1]?.balance || t.balance;
					const balanceColor = t.balance < prevBalance ? 'text-red-600' : 'text-green-600';
					const refColor = t.type === 'withdrawal' ? 'text-red-700' : 'text-green-700';
					return `
						<tr class="border-t border-green-100 h-10">
							<td class="py-2 text-sm">${t.date}</td>
							<td class="py-2 text-sm ${refColor} truncate max-w-[120px]">${t.ref}</td>
							<td class="py-2"><span class="px-1.5 py-0.5 rounded ${status.class} text-xs font-medium">${status.label}</span></td>
							<td class="py-2 text-right ${t.amount.startsWith('+') ? 'text-green-600' : 'text-red-600'} font-semibold text-sm">${t.amount}</td>
							<td class="py-2 text-right ${balanceColor} font-medium text-sm">$${t.balance.toLocaleString()}</td>
						</tr>
					`;
				}).join('');
			}

			document.querySelectorAll('[data-page]').forEach(btn => {
				btn.addEventListener('click', () => {
					const page = parseInt(btn.dataset.page);
					if (!page) {
						currentPage = currentPage === 1 ? 2 : 1;
					} else {
						currentPage = page;
					}
					renderTransactions(currentPage);
					document.querySelectorAll('[data-page]').forEach(b => b.classList.remove('bg-green-700', 'text-white'));
					document.querySelectorAll('[data-page]').forEach(b => b.classList.add('bg-green-50', 'text-green-600'));
					if (currentPage === 1) {
						document.querySelector('[data-page="1"]')?.classList.remove('bg-green-50', 'text-green-600');
						document.querySelector('[data-page="1"]')?.classList.add('bg-green-700', 'text-white');
					} else {
						document.querySelector('[data-page="2"]')?.classList.remove('bg-green-50', 'text-green-600');
						document.querySelector('[data-page="2"]')?.classList.add('bg-green-700', 'text-white');
					}
				});
			});

			renderTransactions(currentPage);

			if (document.getElementById('performanceChart')) {
				const ctx = document.getElementById('performanceChart').getContext('2d');
				const transactions = [
					{ date: '10/Ene', type: 'deposit', amount: 5000, label: 'Deposito inicial', balance: 5000 },
					{ date: '28/Ene', type: 'earning', amount: 350, label: 'Rendimiento Ene', balance: 5350 },
					{ date: '15/Feb', type: 'deposit', amount: 3000, label: 'Transferencia #4490', balance: 8350 },
					{ date: '28/Feb', type: 'earning', amount: 390, label: 'Rendimiento Feb', balance: 8740 },
					{ date: '10/Mar', type: 'deposit', amount: 2000, label: 'Transferencia #4518', balance: 10740 },
					{ date: '15/Mar', type: 'withdrawal', amount: -200, label: 'Banco Pichincha', balance: 10540 },
					{ date: '18/Mar', type: 'deposit', amount: 500, label: 'Transferencia #4521', balance: 11040 },
					{ date: '18/Mar', type: 'deposit', amount: 250, label: 'Efectivo', balance: 11290 }
				];
				new Chart(ctx, {
					type: 'line',
					data: {
						labels: transactions.map(t => t.date),
						datasets: [{
							label: 'Saldo',
							data: transactions.map(t => t.balance),
							borderColor: '#4b8b5f',
							backgroundColor: 'rgba(75, 139, 95, 0.1)',
							fill: true,
							tension: 0.3,
							pointBackgroundColor: transactions.map(t => t.type === 'withdrawal' ? '#dc2626' : '#22c55e'),
							pointBorderColor: '#fff',
							pointBorderWidth: 2,
							pointRadius: 6,
							pointHoverRadius: 8
						}]
					},
					options: {
						responsive: true,
						maintainAspectRatio: false,
						plugins: { 
							legend: { display: false },
							tooltip: {
								callbacks: {
									label: function(context) {
										const t = transactions[context.dataIndex];
										return [
											'Saldo: $' + t.balance.toLocaleString(),
											t.type === 'deposit' ? 'Deposito: +$' + t.amount : t.type === 'withdrawal' ? 'Retiro: $' + t.amount : 'Ganancia: +$' + t.amount,
											t.label
										];
									}
								}
							}
						},
						scales: {
							x: { 
								grid: { display: false }, 
								ticks: { color: '#356444', font: { size: 10 } }
							},
							y: { 
								grid: { color: 'rgba(34, 63, 43, 0.08)' }, 
								ticks: { color: '#356444', font: { size: 10 }, callback: (value) => '$' + value.toLocaleString() }
							}
						}
					}
				});
			}
		</script>
	</body>
</html>
