---
import '../styles/site.css';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
		<title>Dashboard | Eco Negocios e Inversiones</title>
	</head>
	<body class="bg-gradient-to-br from-green-50 to-emerald-100 min-h-screen" data-page="dashboard">
		<div class="flex min-h-screen">
			<aside class="w-64 bg-gradient-to-b from-green-950 to-green-900 border-r border-green-800/30 fixed h-full flex flex-col p-4 gap-4 -translate-x-full md:translate-x-0 z-50" id="dashxSidebar">
				<div class="flex items-center justify-between">
					<a href="/" class="flex items-center gap-3">
						<img src="/images/logos/logo-transparent.png" alt="Eco Negocios" class="w-9 h-9" />
						<div class="hidden md:block">
							<span class="block text-xs text-green-300 uppercase tracking-widest">Eco Negocios</span>
							<strong class="block text-white">Dashboard</strong>
						</div>
					</a>
					<button type="button" class="w-9 h-9 rounded-lg border border-white/10 bg-white/5 text-white md:hidden" id="sidebarToggle">
						<i class="bi bi-list"></i>
					</button>
				</div>

				<nav class="flex flex-col gap-2 mt-4 hidden" id="investorNav">
					<a href="#overview" class="sidebar-btn active" data-target="overview"><i class="bi bi-grid-1x2 mr-2"></i><span class="hidden md:inline">Resumen</span></a>
					<a href="#deposits" class="sidebar-btn" data-target="deposits"><i class="bi bi-plus-circle mr-2"></i><span class="hidden md:inline">Deposito</span></a>
					<a href="#withdrawals" class="sidebar-btn" data-target="withdrawals"><i class="bi bi-arrow-up-circle mr-2"></i><span class="hidden md:inline">Retiro</span></a>
				</nav>

				<nav class="flex flex-col gap-2 mt-4 hidden" id="adminNav">
					<button type="button" class="sidebar-btn active" data-admin-tab="transactions"><i class="bi bi-receipt mr-2"></i><span class="hidden md:inline">Transacciones</span></button>
					<button type="button" class="sidebar-btn" data-admin-tab="graphics"><i class="bi bi-graph-up mr-2"></i><span class="hidden md:inline">Graficos</span></button>
					<button type="button" class="sidebar-btn" data-admin-tab="beneficiaries"><i class="bi bi-people mr-2"></i><span class="hidden md:inline">Beneficiarios</span></button>
				</nav>

				<div class="mt-auto space-y-3">
					<div class="rounded-2xl border border-white/10 bg-white/5 p-3 text-white/90">
						<p class="text-[11px] uppercase tracking-[0.2em] text-green-300">Sesion</p>
						<strong class="block text-sm mt-1" id="sidebarUserName">Cargando...</strong>
						<span class="text-xs text-white/70" id="sidebarUserRole">Sincronizando rol</span>
					</div>
					<button type="button" class="sidebar-btn w-full" id="goProfile"><i class="bi bi-person-circle mr-2"></i><span class="hidden md:inline">Mi perfil</span></button>
					<button type="button" class="sidebar-btn w-full" id="logoutButton"><i class="bi bi-box-arrow-right mr-2"></i><span class="hidden md:inline">Cerrar sesion</span></button>
				</div>
			</aside>

			<div class="fixed inset-0 bg-black/20 z-40 hidden md:hidden" id="dashxOverlay"></div>

			<main class="flex-1 md:ml-64 p-4 md:p-6 w-full">
				<header class="flex items-center justify-between mb-4 md:mb-6">
					<div class="flex items-center gap-3">
						<button type="button" class="md:hidden w-10 h-10 rounded-lg bg-white border border-green-200 shadow flex items-center justify-center text-green-900" id="mobileMenuBtn">
							<i class="bi bi-list text-xl"></i>
						</button>
						<div>
							<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Cuenta</p>
							<h1 class="text-lg md:text-xl font-bold text-green-900" id="dashboardTitle">Cargando dashboard</h1>
						</div>
					</div>
					<div class="flex items-center gap-2 md:gap-3">
						<span class="px-2 md:px-3 py-1 rounded-full bg-white border border-green-200 text-green-700 text-xs md:text-sm font-bold" id="roleBadge">Sin rol</span>
						<div class="relative" id="userMenu">
							<button type="button" class="w-9 md:w-10 h-9 md:h-10 rounded-full bg-white border border-green-200 shadow-lg flex items-center justify-center text-green-900" id="userButton">
								<i class="bi bi-person-circle text-lg md:text-xl"></i>
							</button>
							<div class="absolute right-0 top-full mt-2 w-56 bg-white rounded-xl border border-green-100 shadow-xl hidden" id="userDropdown">
								<div class="p-3 border-b border-green-100">
									<strong class="block text-green-900" id="userName">Cargando...</strong>
									<span class="text-sm text-green-600" id="userEmail">-</span>
								</div>
								<div class="p-2">
									<button type="button" class="flex items-center gap-2 p-2 rounded-lg hover:bg-green-50 text-sm w-full text-left" id="profileShortcut"><i class="bi bi-pencil"></i> Editar perfil</button>
									<button type="button" class="flex items-center gap-2 p-2 rounded-lg hover:bg-green-50 text-sm w-full text-left" id="dropdownLogoutButton"><i class="bi bi-box-arrow-right"></i> Cerrar sesion</button>
								</div>
							</div>
						</div>
					</div>
				</header>

				<section id="overview" class="dashboard-section hidden">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
						<div class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
							<div class="flex items-center gap-3 mb-2">
								<div class="w-10 h-10 rounded-xl bg-green-100 flex items-center justify-center text-green-700"><i class="bi bi-wallet2 text-lg"></i></div>
								<span class="text-xs text-green-600 uppercase font-bold">Saldo actual</span>
							</div>
							<strong class="text-2xl text-green-900" id="currentBalance">$0.00</strong>
							<p class="text-xs text-green-500 mt-1" id="currentBalanceHint">Balance aprobado</p>
						</div>
						<div class="bg-white rounded-2xl p-4 border border-green-100 shadow-sm">
							<div class="flex items-center gap-3 mb-2">
								<div class="w-10 h-10 rounded-xl bg-green-200 flex items-center justify-center text-green-700"><i class="bi bi-graph-up-arrow text-lg"></i></div>
								<span class="text-xs text-green-600 uppercase font-bold">Ganancias</span>
							</div>
							<strong class="text-2xl text-green-900" id="totalEarnings">$0.00</strong>
							<p class="text-xs text-green-500 mt-1">Movimientos tipo rendimiento</p>
						</div>
						<div class="bg-white rounded-2xl p-4 border border-amber-200 shadow-sm">
							<div class="flex items-center gap-3 mb-2">
								<div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center text-amber-700"><i class="bi bi-hourglass-split text-lg"></i></div>
								<span class="text-xs text-amber-600 uppercase font-bold">Depositos pend.</span>
							</div>
							<strong class="text-2xl text-amber-700" id="pendingDeposits">$0.00</strong>
							<p class="text-xs text-amber-500 mt-1" id="pendingDepositsHint">0 solicitudes</p>
						</div>
						<div class="bg-white rounded-2xl p-4 border border-red-200 shadow-sm">
							<div class="flex items-center gap-3 mb-2">
								<div class="w-10 h-10 rounded-xl bg-red-50 flex items-center justify-center text-red-700"><i class="bi bi-cash-stack text-lg"></i></div>
								<span class="text-xs text-red-600 uppercase font-bold">Retiros pend.</span>
							</div>
							<strong class="text-2xl text-red-700" id="pendingWithdrawals">$0.00</strong>
							<p class="text-xs text-red-500 mt-1" id="pendingWithdrawalsHint">0 solicitudes</p>
						</div>
					</div>

					<section id="transactions" class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm mb-6">
						<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-4">
							<div>
								<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Historial</p>
								<h2 class="text-lg font-bold text-green-900">Transacciones</h2>
							</div>
							<div class="flex gap-2">
								<select id="filterType" class="px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm">
									<option value="">Todos</option>
									<option value="deposit">Depositos</option>
									<option value="withdrawal">Retiros</option>
									<option value="earning">Ganancias</option>
								</select>
								<select id="filterStatus" class="px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm">
									<option value="">Todos</option>
									<option value="pending">Pendiente</option>
									<option value="approved">Aprobado</option>
									<option value="paid">Pagado</option>
									<option value="rejected">Rechazado</option>
								</select>
							</div>
						</div>
						<div class="overflow-x-auto">
							<table class="w-full min-w-[700px]">
								<thead>
									<tr class="text-left text-xs text-green-600 font-semibold">
										<th class="pb-2 w-28">Fecha</th>
										<th class="pb-2">Referencia</th>
										<th class="pb-2 w-32">Estado</th>
										<th class="pb-2 w-24 text-right">Monto</th>
										<th class="pb-2 w-24 text-right">Saldo</th>
										<th class="pb-2 w-28 text-right">Soporte</th>
									</tr>
								</thead>
								<tbody id="transactionsTableBody"></tbody>
							</table>
						</div>
						<div class="flex items-center justify-between mt-3 pt-3 border-t border-green-100 text-xs text-green-600">
							<span id="transactionsSummary">Sin movimientos</span>
							<div class="flex gap-1">
								<button type="button" class="px-2 py-1 rounded text-xs bg-green-100 text-green-700 font-medium" data-page-action="prev">&laquo;</button>
								<button type="button" class="px-2 py-1 rounded text-xs bg-green-700 text-white font-medium" data-page-number="1">1</button>
								<button type="button" class="px-2 py-1 rounded text-xs bg-green-50 text-green-600 hover:bg-green-100" data-page-number="2">2</button>
								<button type="button" class="px-2 py-1 rounded text-xs bg-green-100 text-green-700 font-medium" data-page-action="next">&raquo;</button>
							</div>
						</div>
					</section>

					<section id="chartSection" class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm mb-6">
						<div class="mb-4">
							<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Rendimiento</p>
							<h2 class="text-lg font-bold text-green-900">Evolucion del saldo</h2>
						</div>
						<div class="h-56">
							<canvas id="performanceChart"></canvas>
						</div>
					</section>
				</section>

				<section id="deposits" class="dashboard-section hidden grid md:grid-cols-2 gap-4">
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<div class="flex items-center justify-between mb-4">
							<div>
								<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Nuevo deposito</p>
								<h2 class="text-lg font-bold text-green-900">Registrar deposito</h2>
							</div>
							<i class="bi bi-plus-circle-fill text-2xl text-green-700"></i>
						</div>
						<form id="depositForm" class="space-y-3">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Monto USD</span>
								<input type="number" min="1" step="0.01" name="amount" placeholder="250.00" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Referencia bancaria</span>
								<input type="text" name="reference" placeholder="Numero o descripcion" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Comprobante</span>
								<div class="relative">
									<input type="file" id="depositFile" name="file" accept="image/*,.pdf" class="hidden" required />
									<label for="depositFile" class="flex items-center justify-center w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50 cursor-pointer hover:bg-green-100 transition-colors">
										<i class="bi bi-cloud-arrow-up text-green-600 mr-2"></i>
										<span class="text-green-600 text-sm" id="depositFileName">Subir imagen o PDF</span>
									</label>
								</div>
								<div id="depositPreview" class="mt-2 relative inline-block hidden">
									<img id="depositPreviewImg" class="w-24 h-24 object-cover rounded-lg border border-green-200 hidden" />
									<div id="depositPreviewDoc" class="hidden px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm text-green-700"></div>
									<button type="button" id="depositRemoveImg" class="absolute -top-2 -right-2 w-6 h-6 bg-red-500 text-white rounded-full hidden items-center justify-center text-xs hover:bg-red-600">&times;</button>
								</div>
							</label>
							<button type="submit" class="w-full py-3 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg">Enviar deposito</button>
						</form>
					</div>
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold mb-2">Flujo</p>
						<h3 class="text-lg font-bold text-green-950 mb-4">Antes de enviar</h3>
						<ol class="space-y-3 text-sm text-green-800">
							<li class="rounded-2xl bg-green-50 border border-green-100 px-4 py-3">1. Verifica que el monto y la referencia sean correctos.</li>
							<li class="rounded-2xl bg-green-50 border border-green-100 px-4 py-3">2. Adjunta un comprobante legible.</li>
							<li class="rounded-2xl bg-green-50 border border-green-100 px-4 py-3">3. Revisa el estado del deposito desde tu historial.</li>
						</ol>
					</div>
				</section>

				<section id="withdrawals" class="dashboard-section hidden grid md:grid-cols-2 gap-4">
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<div class="flex items-center justify-between mb-4">
							<div>
								<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Nuevo retiro</p>
								<h2 class="text-lg font-bold text-green-900">Solicitar retiro</h2>
							</div>
							<i class="bi bi-arrow-up-right-circle-fill text-2xl text-green-700"></i>
						</div>
						<form id="withdrawForm" class="space-y-3">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Monto USD</span>
								<input type="number" min="1" step="0.01" name="amount" placeholder="120.00" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<div class="grid grid-cols-2 gap-3">
								<label class="block">
									<span class="block text-sm font-bold text-green-900 mb-1">Banco</span>
									<input type="text" name="bank" placeholder="Banco" class="w-full px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm" required />
								</label>
								<label class="block">
									<span class="block text-sm font-bold text-green-900 mb-1">Nro. Cuenta</span>
									<input type="text" name="account" placeholder="Cuenta" class="w-full px-3 py-2 rounded-lg border border-green-200 bg-green-50 text-sm" required />
								</label>
							</div>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Cedula / ID</span>
								<input type="text" name="cedula" placeholder="V-12345678" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Nombre completo</span>
								<input type="text" name="name" placeholder="Juan Perez" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Correo electronico</span>
								<input type="email" name="email" placeholder="correo@email.com" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Telefono de contacto</span>
								<input type="tel" name="phone" placeholder="+54 11 1234 5678" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<button type="submit" class="w-full py-3 rounded-full bg-emerald-100 text-green-800 font-bold border border-green-200">Solicitar retiro</button>
						</form>
					</div>
					<div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold mb-2">Estado</p>
						<h3 class="text-lg font-bold text-green-950 mb-4">Antes de solicitar</h3>
						<ul class="space-y-3 text-sm text-green-800">
							<li class="rounded-2xl bg-emerald-50 border border-emerald-100 px-4 py-3">Confirma que los datos bancarios esten actualizados.</li>
							<li class="rounded-2xl bg-emerald-50 border border-emerald-100 px-4 py-3">Revisa el monto antes de enviar la solicitud.</li>
							<li class="rounded-2xl bg-emerald-50 border border-emerald-100 px-4 py-3">Consulta el avance del retiro desde tu historial.</li>
						</ul>
					</div>
				</section>

				<section id="profile" class="dashboard-section hidden bg-white rounded-2xl p-5 border border-green-100 shadow-sm">
					<div class="mb-4">
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Cuenta</p>
						<h2 class="text-lg font-bold text-green-900">Mi perfil</h2>
					</div>
					<form id="profileForm" class="space-y-4">
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Nombre completo</span>
								<input type="text" name="name" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Email</span>
								<input type="email" name="email" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" required />
							</label>
						</div>
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Telefono</span>
								<input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Cedula / ID</span>
								<input type="text" name="cedula" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" />
							</label>
						</div>
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Banco</span>
								<input type="text" name="bankName" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Nro. Cuenta</span>
								<input type="text" name="accountNumber" class="w-full px-4 py-3 rounded-xl border border-green-200 bg-green-50" />
							</label>
						</div>
						<div class="grid md:grid-cols-2 gap-4">
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">Estado</span>
								<input type="text" name="status" class="w-full px-4 py-3 rounded-xl border border-green-100 bg-gray-50 text-gray-500" disabled />
							</label>
							<label class="block">
								<span class="block text-sm font-bold text-green-900 mb-1">ID de cuenta</span>
								<input type="text" name="uid" class="w-full px-4 py-3 rounded-xl border border-green-100 bg-gray-50 text-gray-500" disabled />
							</label>
						</div>
						<button type="submit" class="py-3 px-6 rounded-full bg-gradient-to-r from-green-500 to-emerald-400 text-white font-bold shadow-lg">Guardar cambios</button>
					</form>
				</section>

				<section id="adminPanel" class="dashboard-section hidden">
					<div class="mb-4">
						<h2 class="text-xl font-bold text-gray-900">Panel de administracion</h2>
						<p class="text-sm text-gray-500">Gestion general de transacciones y beneficiarios.</p>
					</div>

					<div id="adminTransactions" class="admin-tab-content">
						<div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
							<div class="flex items-center justify-between mb-4 gap-3">
								<div>
									<p class="text-xs text-gray-500 uppercase tracking-widest font-bold">Admin</p>
									<h3 class="text-lg font-bold text-gray-900">Todas las transacciones</h3>
								</div>
								<select id="adminStatusFilter" class="px-3 py-2 rounded-lg border border-gray-200 text-sm">
									<option value="">Todos los estados</option>
									<option value="pending">Pendiente</option>
									<option value="approved">Aprobado</option>
									<option value="paid">Pagado</option>
									<option value="rejected">Rechazado</option>
								</select>
							</div>
							<div class="overflow-x-auto">
								<table class="w-full min-w-[960px]">
									<thead>
										<tr class="text-left text-xs text-gray-500 font-semibold border-b">
											<th class="pb-2 w-28">Fecha</th>
											<th class="pb-2">Usuario</th>
											<th class="pb-2">Referencia</th>
											<th class="pb-2 w-32">Estado</th>
											<th class="pb-2 w-24 text-right">Monto</th>
											<th class="pb-2 w-24">Tipo</th>
											<th class="pb-2 w-20 text-center">Soporte</th>
											<th class="pb-2 w-28 text-right">Accion</th>
