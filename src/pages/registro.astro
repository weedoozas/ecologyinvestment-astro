---
import '../styles/site.css';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/images/logos/logo-transparent.png" />
		<title>Registro | Eco Negocios e Inversiones</title>
	</head>
	<body class="min-h-screen flex items-center justify-center relative p-4" style="background: linear-gradient(180deg, rgba(232,250,235,0.88) 0%, rgba(245,252,247,0.96) 100%), url('/images/greenprojects.png') center center/cover no-repeat;" data-page="register" data-auth-mode="register">
		<div class="absolute inset-0 bg-gradient-to-br from-green-950/10 via-transparent to-emerald-500/10 pointer-events-none"></div>
		<div class="relative w-full max-w-md">
			<section class="bg-white/70 backdrop-blur-xl rounded-3xl p-6 md:p-8 shadow-2xl border border-white/30">
				<div class="flex items-center gap-3 md:gap-4 mb-5 md:mb-6">
					<img src="/images/logos/logo-transparent.png" alt="Eco Negocios" class="w-20 md:w-24 h-8 md:h-10 object-contain" />
					<div>
						<p class="text-xs text-green-600 uppercase tracking-widest font-bold">Firebase Auth</p>
						<h1 class="text-xl md:text-2xl font-bold text-green-950" id="loginTitle">Crear cuenta</h1>
					</div>
				</div>

				<form id="loginForm" class="space-y-4 mb-4">
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Nombre completo</span>
						<input type="text" name="name" placeholder="Tu nombre" class="w-full px-4 py-3 rounded-2xl border border-green-200 bg-white/90 text-base" required />
					</label>
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Correo</span>
						<input type="email" name="email" placeholder="usuario@eco.com" class="w-full px-4 py-3 rounded-2xl border border-green-200 bg-white/90 text-base" required />
					</label>
					<label class="block">
						<span class="block text-sm font-bold text-green-900 mb-1">Contrasena</span>
						<input type="password" name="password" placeholder="Minimo 6 caracteres" class="w-full px-4 py-3 rounded-2xl border border-green-200 bg-white/90 text-base" required />
					</label>
					<button type="submit" class="w-full py-3 rounded-full bg-gradient-to-r from-green-600 to-emerald-400 text-white font-bold shadow-lg">Crear cuenta</button>
				</form>

				<div class="flex items-center gap-3 mb-4 text-xs uppercase tracking-[0.3em] text-green-600/70">
					<span class="h-px flex-1 bg-green-200"></span>
					<span>o</span>
					<span class="h-px flex-1 bg-green-200"></span>
				</div>

				<div class="space-y-4">
					<button type="button" id="googleAuthButton" class="w-full py-3 px-4 rounded-full bg-white text-green-950 font-bold shadow-lg border border-green-200 flex items-center justify-center gap-3">
						<svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
							<path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.6 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.7 1.1 7.8 3l5.7-5.7C34.1 6.1 29.4 4 24 4C12.9 4 4 12.9 4 24s8.9 20 20 20s20-8.9 20-20c0-1.3-.1-2.3-.4-3.5Z"/>
							<path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15 18.9 12 24 12c3 0 5.7 1.1 7.8 3l5.7-5.7C34.1 6.1 29.4 4 24 4c-7.7 0-14.4 4.3-17.7 10.7Z"/>
							<path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.5-5.2l-6.2-5.2C29.3 35.1 26.8 36 24 36c-5.2 0-9.6-3.3-11.3-8l-6.6 5.1C9.3 39.6 16.1 44 24 44Z"/>
							<path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4 5.6l.1-.1l6.2 5.2C37.2 38.4 44 33 44 24c0-1.3-.1-2.3-.4-3.5Z"/>
						</svg>
						<span>Continuar con Google</span>
					</button>
					<p class="text-center text-sm min-h-5 font-medium" id="loginMessage"></p>
				</div>

				<div class="flex flex-col md:flex-row justify-between mt-5 text-sm gap-2 text-green-700">
					<a href="/login" class="hover:text-green-900">Ya tengo cuenta</a>
					<a href="/" class="hover:text-green-900">Volver a la landing</a>
				</div>
			</section>
		</div>

		<script>
			import { initLoginPage } from '../scripts/login';

			initLoginPage();
		</script>
	</body>
</html>
